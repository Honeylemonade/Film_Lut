<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:background="@color/card">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/textPrimary" />

            <TextView
                android:id="@+id/currentServerLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/not_connected"
                android:textSize="12sp"
                android:textColor="@color/textMuted" />
        </LinearLayout>

        <Button
            android:id="@+id/serverButton"
            style="@style/Widget.FilmLut.ToolbarButton"
            android:text="@string/server_button" />

        <Button
            android:id="@+id/reloadButton"
            style="@style/Widget.FilmLut.ToolbarButton"
            android:layout_marginStart="8dp"
            android:text="@string/reload_button" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:indeterminate="true"
        android:visibility="gone" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ScrollView
            android:id="@+id/setupGroup"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:background="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_title"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:textColor="@color/textPrimary" />

                <TextView
                    android:id="@+id/serverDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="@color/textMuted"
                    android:lineSpacingExtra="4dp" />

                <EditText
                    android:id="@+id/serverUrlInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:hint="@string/server_input_hint"
                    android:inputType="textUri"
                    android:padding="14dp"
                    android:background="@drawable/bg_field" />

                <Button
                    android:id="@+id/saveServerButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/connect_button" />

                <Button
                    android:id="@+id/emulatorHintButton"
                    style="@style/Widget.FilmLut.SecondaryButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/use_emulator_button" />
            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:id="@+id/errorGroup"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:visibility="gone"
            android:background="@color/surface">

            <TextView
                android:id="@+id/errorMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/textPrimary"
                android:lineSpacingExtra="4dp" />

            <Button
                android:id="@+id/retryButton"
                style="@style/Widget.FilmLut.SecondaryButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/retry_button" />
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
