    <string name="control_group_basic_title">基础</string>
    <string name="control_group_basic_summary">先决定 LUT 强度和整体空气感，快速定下主风格。</string>
    <string name="control_group_optics_title">光学</string>
    <string name="control_group_optics_summary">围绕镜头观感微调，包括色散、暗角、锐度和局部反差。</string>
    <string name="control_group_tone_title">色调</string>
    <string name="control_group_tone_summary">处理高光肩部、阴影脚部和不同亮度区域的饱和度。</string>
    <string name="control_group_texture_title">质感</string>
    <string name="control_group_texture_summary">补足胶片味最明显的颗粒、halation、bloom 和阴影抬升。</string>
    <string name="group_collapse">收起</string>
    <string name="group_expand">展开</string>
    <string name="control_value_format">%1$d</string>
    <string name="control_lut_intensity_title">LUT 强度</string>
    <string name="control_lut_intensity_summary">控制 LUT 套用比例，方便保留更多原图层次。</string>
    <string name="control_grain_title">颗粒</string>
    <string name="control_grain_summary">增加胶片颗粒噪点，适合做纪实和高感质感。</string>
    <string name="control_dispersion_title">色散</string>
    <string name="control_dispersion_summary">轻微拉开红蓝通道，模拟镜头边缘色散。</string>
    <string name="control_vignette_title">暗角</string>
    <string name="control_vignette_summary">让视线更集中到画面中央，营造胶片镜头压暗边缘的感觉。</string>
    <string name="control_sharpen_title">锐化</string>
    <string name="control_sharpen_summary">正值更锐，负值更软，用来控制边缘力度。</string>
    <string name="control_clarity_title">清晰度</string>
    <string name="control_clarity_summary">调整局部反差，正值更硬朗，负值更柔和。</string>
    <string name="control_rolloff_title">高光滚降</string>
    <string name="control_rolloff_summary">压住高光，减少数码感的发白和突兀溢出。</string>
    <string name="control_halation_title">Halation</string>
    <string name="control_halation_summary">为高光叠加暖色晕染，模拟胶片亮部红边。</string>
    <string name="control_bloom_title">Bloom</string>
    <string name="control_bloom_summary">给亮部增加柔光泛开，让画面更有空气感。</string>
    <string name="control_shadow_lift_title">阴影抬升</string>
    <string name="control_shadow_lift_summary">提亮暗部，做出更有胶片宽容度的黑位。</string>
    <string name="control_toe_title">Toe</string>
    <string name="control_toe_summary">调整阴影脚部，增强雾面、粉感和底片脚感。</string>
    <string name="control_shoulder_title">Shoulder</string>
    <string name="control_shoulder_summary">控制高光肩部过渡，让亮部更柔顺。</string>
    <string name="control_highlight_sat_title">高光饱和度</string>
    <string name="control_highlight_sat_summary">单独控制高光区域的颜色浓度。</string>
    <string name="control_shadow_sat_title">阴影饱和度</string>
    <string name="control_shadow_sat_summary">单独控制暗部区域的颜色浓度。</string>
    <string name="control_highlight_warmth_title">高光暖调</string>
    <string name="control_highlight_warmth_summary">给亮部加一点偏暖色温，适合日落和人像。</string>
    <string name="control_shadow_coolness_title">阴影冷调</string>
    <string name="control_shadow_coolness_summary">给阴影加蓝冷感，形成更明显的冷暖对比。</string>
