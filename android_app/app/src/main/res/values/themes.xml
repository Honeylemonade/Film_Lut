<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.FilmLutAndroid" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/brand</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/editor_chip_bg</item>
        <item name="colorOnPrimaryContainer">@color/ink_900</item>
        <item name="colorSecondary">@color/mint</item>
        <item name="colorOnSecondary">@color/ink_900</item>
        <item name="colorSurface">@color/editor_bg</item>
        <item name="colorSurfaceVariant">@color/editor_panel</item>
        <item name="colorOnSurface">@color/ink_900</item>
        <item name="colorOutline">@color/editor_line</item>
        <item name="android:statusBarColor" tools:targetApi="l">@android:color/transparent</item>
        <item name="android:navigationBarColor" tools:targetApi="l">@color/editor_nav_bg</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
        <item name="materialCardViewStyle">@style/Widget.FilmLut.Card</item>
        <item name="chipStyle">@style/Widget.FilmLut.Chip</item>
        <item name="bottomNavigationStyle">@style/Widget.FilmLut.BottomNav</item>
    </style>

    <style name="Widget.FilmLut.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">18dp</item>
        <item name="cardBackgroundColor">@color/editor_panel</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/editor_line</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.FilmLut.Button" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">52dp</item>
    </style>

    <style name="Widget.FilmLut.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">52dp</item>
    </style>

    <style name="Widget.FilmLut.Chip" parent="Widget.Material3.Chip.Assist">
        <item name="chipBackgroundColor">@color/editor_chip_bg</item>
        <item name="chipStrokeColor">@color/editor_line</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/ink_900</item>
    </style>

    <style name="Widget.FilmLut.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="itemActiveIndicatorStyle">@style/Widget.FilmLut.BottomNav.ActiveIndicator</item>
    </style>

    <style name="Widget.FilmLut.BottomNav.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/surface_alt</item>
        <item name="shapeAppearance">@style/ShapeAppearance.FilmLut.BottomNav.ActiveIndicator</item>
    </style>

    <style name="ShapeAppearance.FilmLut.BottomNav.ActiveIndicator" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>

    <style name="Widget.FilmLut.Button.EditorGhost" parent="Widget.Material3.Button.TextButton">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:minHeight">42dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="backgroundTint">@color/editor_chip_bg</item>
        <item name="android:textColor">@color/ink_900</item>
        <item name="iconTint">@color/ink_700</item>
    </style>

    <style name="Widget.FilmLut.Button.EditorTool" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:minHeight">44dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textColor">@color/ink_900</item>
        <item name="strokeColor">@color/editor_line</item>
        <item name="backgroundTint">@color/tool_toggle_bg_notion</item>
        <item name="android:textColor">@color/tool_toggle_text_notion</item>
    </style>

    <style name="Widget.FilmLut.EditorChip" parent="Widget.Material3.Chip.Assist">
        <item name="chipBackgroundColor">@color/editor_chip_bg</item>
        <item name="chipStrokeColor">@android:color/transparent</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="android:textColor">@color/ink_900</item>
    </style>

    <style name="Widget.FilmLut.BottomNav.ActiveIndicator.Dark" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/editor_chip_bg</item>
        <item name="shapeAppearance">@style/ShapeAppearance.FilmLut.BottomNav.ActiveIndicator</item>
    </style>
</resources>
