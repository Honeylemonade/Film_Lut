<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_dark_meta_panel"
    android:orientation="vertical"
    android:paddingStart="10dp"
    android:paddingTop="8dp"
    android:paddingEnd="10dp"
    android:paddingBottom="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/controlTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/ink_900"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/controlValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/editor_text_muted"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/controlSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/editor_text_soft"
        android:textSize="11sp" />

    <com.google.android.material.slider.Slider
        android:id="@+id/controlSlider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:valueFrom="0"
        android:valueTo="100" />
</LinearLayout>
