<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/editor_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/heroTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hero_title"
                android:textColor="@color/ink_900"
                android:textSize="16sp"
                android:textStyle="bold" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/heroSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/hero_subtitle_compact"
                android:textColor="@color/editor_text_muted"
                android:textSize="11sp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/pickImageButton"
                style="@style/Widget.FilmLut.Button.EditorGhost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="40dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:text=""
                app:icon="@drawable/ic_photo_library"
                app:iconGravity="textTop"
                app:iconPadding="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/exportButton"
                style="@style/Widget.FilmLut.Button.EditorGhost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:enabled="false"
                android:minWidth="40dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:text=""
                app:icon="@drawable/ic_download"
                app:iconGravity="textTop"
                app:iconPadding="0dp" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/editTab"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1.56"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <FrameLayout
                        android:id="@+id/previewSurface"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_editor_preview"
                        android:foreground="?attr/selectableItemBackground">

                        <ImageView
                            android:id="@+id/previewImage"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:adjustViewBounds="true"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter" />

                        <TextView
                            android:id="@+id/previewPlaceholder"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:padding="40dp"
                            android:text="@string/preview_hint_short"
                            android:textColor="@color/editor_text_soft"
                            android:textSize="15sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="top"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="10dp"
                            android:paddingTop="10dp"
                            android:paddingEnd="10dp"
                            android:paddingBottom="10dp">

                            <TextView
                                android:id="@+id/photoCountChip"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_dark_meta_chip"
                                android:paddingStart="8dp"
                                android:paddingTop="4dp"
                                android:paddingEnd="8dp"
                                android:paddingBottom="4dp"
                                android:text="@string/no_photos_selected"
                                android:textColor="@color/ink_700"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/heroOutputChip"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_dark_meta_chip"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:visibility="gone"
                                android:paddingStart="9dp"
                                android:paddingTop="5dp"
                                android:paddingEnd="9dp"
                                android:paddingBottom="5dp"
                                android:text="@string/export_combo_summary_zero"
                                android:textColor="@color/editor_text_muted"
                                android:textSize="10sp" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="1dp"
                                android:layout_weight="1" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/compareButton"
                                style="@style/Widget.FilmLut.Button.EditorGhost"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:enabled="false"
                                android:minWidth="40dp"
                                android:paddingStart="0dp"
                                android:paddingEnd="0dp"
                                android:text=""
                                app:icon="@drawable/ic_compare"
                                app:iconGravity="textTop"
                                app:iconPadding="0dp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/previewTapHint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|end"
                            android:layout_margin="10dp"
                            android:background="@drawable/bg_preview_hint_dark"
                            android:paddingStart="10dp"
                            android:paddingTop="6dp"
                            android:paddingEnd="10dp"
                            android:paddingBottom="6dp"
                            android:text="@string/preview_overlay_hint"
                            android:textColor="@color/ink_900"
                            android:textSize="11sp"
                            android:visibility="gone" />

                        <LinearLayout
                            android:id="@+id/progressOverlay"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#88000000"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <ProgressBar
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:indeterminateTint="@color/white" />

                            <TextView
                                android:id="@+id/progressLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="@string/status_processing"
                                android:textColor="@color/ink_900"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </FrameLayout>
                </FrameLayout>

                <LinearLayout
                    android:id="@+id/editPhotoRail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="14dp"
                    android:paddingTop="0dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="0dp"
                    android:visibility="gone">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/categoryChip"
                        style="@style/Widget.FilmLut.EditorChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tag_selected"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/selectedPhotoMeta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/editor_text_muted"
                        android:textSize="11sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/statusText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/preview_hint_compact"
                        android:textColor="@color/editor_text_soft"
                        android:textSize="11sp"
                        android:visibility="gone" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/editPhotoRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"
                        android:clipToPadding="false"
                        android:paddingEnd="14dp" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="236dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:layout_marginBottom="8dp"
                    app:cardBackgroundColor="@color/editor_panel"
                    app:cardCornerRadius="18dp"
                    app:strokeColor="@color/editor_line"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp">

                        <com.google.android.material.button.MaterialButtonToggleGroup
                            android:id="@+id/editToolToggleGroup"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_marginEnd="14dp"
                            app:selectionRequired="true"
                            app:singleSelection="true">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/toolLutButton"
                                style="@style/Widget.FilmLut.Button.EditorTool"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/nav_luts" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/toolFilmButton"
                                style="@style/Widget.FilmLut.Button.EditorTool"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/nav_film" />
                        </com.google.android.material.button.MaterialButtonToggleGroup>

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_marginTop="8dp"
                            android:layout_weight="1">

                            <LinearLayout
                                android:id="@+id/lutsTab"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical">

                                <HorizontalScrollView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fillViewport="false"
                                    android:paddingStart="14dp"
                                    android:paddingEnd="14dp"
                                    android:scrollbars="none">

                                    <com.google.android.material.chip.ChipGroup
                                        android:id="@+id/lutCategoryGroup"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        app:chipSpacingHorizontal="8dp"
                                        app:chipSpacingVertical="8dp"
                                        app:singleSelection="true" />
                                </HorizontalScrollView>

                                <TextView
                                    android:id="@+id/lutSectionSubtitle"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="14dp"
                                    android:layout_marginTop="8dp"
                                    android:layout_marginEnd="14dp"
                                    android:ellipsize="end"
                                    android:maxLines="1"
                                    android:textColor="@color/editor_text_soft"
                                    android:textSize="12sp"
                                    android:visibility="gone" />

                                <androidx.recyclerview.widget.RecyclerView
                                    android:id="@+id/lutRecyclerView"
                                    android:layout_width="match_parent"
                                    android:layout_height="0dp"
                                    android:layout_marginTop="8dp"
                                    android:layout_weight="1"
                                    android:clipToPadding="false"
                                    android:paddingStart="14dp"
                                    android:paddingEnd="14dp" />
                            </LinearLayout>

                            <androidx.core.widget.NestedScrollView
                                android:id="@+id/filmTab"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:fillViewport="true"
                                android:visibility="gone">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:paddingStart="14dp"
                                    android:paddingEnd="14dp">

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:gravity="center_vertical"
                                        android:orientation="horizontal">

                                        <TextView
                                            android:id="@+id/filmTabSubtitle"
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:layout_weight="1"
                                            android:text="@string/film_tab_subtitle_short"
                                            android:ellipsize="end"
                                            android:maxLines="2"
                                            android:textColor="@color/editor_text_soft"
                                            android:textSize="12sp"
                                            android:visibility="gone" />

                                        <View
                                            android:layout_width="0dp"
                                            android:layout_height="1dp"
                                            android:layout_weight="1" />

                                        <com.google.android.material.button.MaterialButton
                                            android:id="@+id/resetAdjustmentsButton"
                                            style="@style/Widget.FilmLut.Button.EditorGhost"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:minHeight="36dp"
                                            android:paddingStart="16dp"
                                            android:paddingEnd="16dp"
                                            android:text="@string/reset_adjustments_short" />
                                    </LinearLayout>

                                    <TextView
                                        android:id="@+id/adjustmentDigest"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="10dp"
                                        android:background="@drawable/bg_dark_meta_panel"
                                        android:paddingStart="12dp"
                                        android:paddingTop="10dp"
                                        android:paddingEnd="12dp"
                                        android:paddingBottom="10dp"
                                        android:text="@string/adjustment_digest_empty"
                                        android:textColor="@color/ink_900"
                                        android:textSize="12sp"
                                        android:visibility="gone" />

                                    <LinearLayout
                                        android:id="@+id/filmControlsContainer"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="0dp"
                                        android:orientation="vertical" />

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="12dp"
                                        android:gravity="center_vertical"
                                        android:orientation="horizontal">

                                        <TextView
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:layout_weight="1"
                                            android:text="@string/section_presets"
                                            android:textColor="@color/ink_900"
                                            android:textSize="13sp"
                                            android:textStyle="bold" />

                                        <com.google.android.material.button.MaterialButton
                                            android:id="@+id/savePresetButton"
                                            style="@style/Widget.FilmLut.Button.EditorGhost"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="@string/save_preset" />
                                    </LinearLayout>

                                    <TextView
                                        android:id="@+id/presetSummary"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="@string/preset_section_subtitle"
                                        android:textColor="@color/editor_text_soft"
                                        android:textSize="12sp" />

                                    <androidx.recyclerview.widget.RecyclerView
                                        android:id="@+id/presetRecyclerView"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="10dp"
                                        android:nestedScrollingEnabled="false" />
                                </LinearLayout>
                            </androidx.core.widget.NestedScrollView>
                        </FrameLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <androidx.core.widget.NestedScrollView
                android:id="@+id/batchTab"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="14dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="14dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/editor_panel"
                        app:strokeColor="@color/editor_line"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:id="@+id/projectTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/project_empty_title"
                                android:textColor="@color/ink_900"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/projectMeta"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/project_empty_meta"
                                android:textColor="@color/editor_text_soft"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/projectFocus"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="@string/project_focus_empty"
                                android:textColor="@color/editor_text_muted"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:cardBackgroundColor="@color/editor_panel"
                        app:strokeColor="@color/editor_line"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:id="@+id/photosTabSubtitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/photos_tab_subtitle"
                                android:textColor="@color/editor_text_soft"
                                android:textSize="12sp" />

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/photoRecyclerView"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="14dp"
                                android:clipToPadding="false"
                                android:nestedScrollingEnabled="false"
                                android:paddingBottom="8dp" />

                            <TextView
                                android:id="@+id/photoBatchSummary"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/bg_dark_meta_panel"
                                android:paddingStart="12dp"
                                android:paddingTop="10dp"
                                android:paddingEnd="12dp"
                                android:paddingBottom="10dp"
                                android:textColor="@color/editor_text_muted"
                                android:textSize="12sp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/reselectButton"
                                style="@style/Widget.FilmLut.Button.EditorGhost"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="@string/reselect_photos" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/batchExportButton"
                                style="@style/Widget.FilmLut.Button.EditorGhost"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:enabled="false"
                                android:text="@string/export_batch" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </FrameLayout>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/editor_nav_bg"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            app:itemActiveIndicatorStyle="@style/Widget.FilmLut.BottomNav.ActiveIndicator.Dark"
            app:itemIconTint="@color/nav_item_colors_dark"
            app:itemTextColor="@color/nav_item_colors_dark"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/bottom_nav_menu" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/fullPreviewOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F20A0A0A"
        android:padding="18dp"
        android:visibility="gone">

        <com.filmlut.android.ui.ZoomImageView
            android:id="@+id/fullPreviewImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:adjustViewBounds="true"
            android:contentDescription="@null"
            android:scaleType="fitCenter" />

        <ImageButton
            android:id="@+id/closeFullPreviewButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="top|end"
            android:background="@drawable/bg_dark_meta_chip"
            android:contentDescription="@string/close_preview"
            android:padding="10dp"
            android:src="@drawable/ic_close"
            app:tint="@color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fullPreviewCompareButton"
            style="@style/Widget.FilmLut.Button.EditorGhost"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="22dp"
            android:enabled="false"
            android:minWidth="128dp"
            android:text="@string/compare_original"
            app:icon="@drawable/ic_compare"
            app:iconGravity="textStart"
            app:iconPadding="8dp" />
    </FrameLayout>
</FrameLayout>
